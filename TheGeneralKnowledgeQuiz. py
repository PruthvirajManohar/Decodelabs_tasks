def run_quiz():
    print("Welcome to the General Knowledge Quiz!")
    print("-" * 40)

    score = 0

    q1 = input("Question 1: What is the capital of France? ")
    if q1.strip().lower() == "paris":
        print("Correct!\n")
        score += 1
    else:
        print("Incorrect. The answer is Paris.\n")

    q2 = input("Question 2: What is the chemical symbol for water? ")
    if q2.strip().lower() == "h2o":
        print("Correct!\n")
        score += 1
    else:
        print("Incorrect. The answer is H2O.\n")

    q3 = input("Question 3: What planet is known as the Red Planet? ")
    if q3.strip().lower() == "mars":
        print("Correct!\n")
        score += 1
    else:
        print("Incorrect. The answer is Mars.\n")

    print("-" * 40)
    print(f"Quiz Complete! Your final score is: {score:>2}/3")

if __name__ == "__main__":
    run_quiz()
